FORGEML_ENV=local
FORGEML_DATABASE_URL=postgresql+psycopg://forgeml:forgeml@localhost:5432/forgeml
FORGEML_REDIS_URL=redis://localhost:6379/0
FORGEML_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
FORGEML_OBJECT_STORAGE_BUCKET=forgeml-artifacts
FORGEML_MLFLOW_TRACKING_URI=http://localhost:5000
FORGEML_AIRFLOW_BASE_URL=http://localhost:8080
FORGEML_JWT_SECRET=change-me-for-local-development
FORGEML_CORS_ORIGINS=["http://localhost:5173"]
FORGEML_RATE_LIMIT_ENABLED=true
FORGEML_RATE_LIMIT_REQUESTS=120
FORGEML_RATE_LIMIT_WINDOW_SECONDS=60
FORGEML_RATE_LIMIT_EXEMPT_PATHS=["/health/live","/health/ready","/metrics","/docs","/redoc","/openapi.json"]
